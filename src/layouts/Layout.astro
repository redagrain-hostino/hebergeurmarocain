---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";

interface Props {
    title?: string;
    description?: string;
}

const {
    title = "Hébergeur Marocain - Meilleur hébergement web au Maroc",
    description = "Comparatif des meilleurs hébergeurs web au Maroc. Trouvez l'hébergement web idéal pour votre site.",
} = Astro.props;
---

<!doctype html>
<html lang="fr">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <title>{title}</title>
        <link rel="icon" type="image/x-icon" href="/favicon.ico" />
        <!-- Elementor / theme CSS served as static assets, no JS import -->

        <!-- Google Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Source+Serif+4:wght@700&display=swap"
            rel="stylesheet"
        />
        <!-- Font Awesome for icons -->
        <link
            rel="stylesheet"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        />
    </head>
    <body>
        <Header />
        <slot />
        <Footer />
    </body>
</html>

<style is:global>
    :root {
        --color-primary: #7d00ff;
        --color-secondary: #242424;
        --color-text: #7e7e7e;
        --color-accent: #cfc2ff;
        --color-white: #ffffff;

        --font-heading: "Poppins", sans-serif;
        --font-body: "Poppins", sans-serif;
        --font-nav: "Montserrat", sans-serif;

        --fs-h1: 32px;
        --fs-h2: 24px;
        --fs-h3: 20.8px;
        --fs-p: 14px;

        --space-sm: 0.67rem;
        --space-md: 1rem;
        --space-lg: 1.5rem;
        --space-xl: 2.25rem;
        --space-2xl: 3.38rem;

        --shadow-natural: 6px 6px 9px rgba(0, 0, 0, 0.2);
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-size: 16px;
        font-family: "Montserrat", sans-serif;
    }
</style>
