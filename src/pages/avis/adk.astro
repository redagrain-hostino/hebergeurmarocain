---
import Layout from "../../layouts/Layout.astro";
import AvisBestSeller from "../../components/AvisBestSeller.astro";
---

<Layout title="Avis ADK Media - Hébergeur Marocain">
    <section class="adk-hero-section">
        <div class="adk-hero-bg-overlay" aria-hidden="true"></div>

        <div class="adk-hero-container">
            <!-- Left Column: Text Content -->
            <div class="adk-hero-content">
                <h1 class="adk-hero-title-small">Classement des meilleurs hébergeurs</h1>
                <h2 class="adk-hero-title-main">Avis ADK Media et test 2025</h2>
            </div>

            <!-- Right Column: Logo/Image -->
            <div class="adk-hero-image-col">
                <img
                    decoding="async"
                    width="204"
                    height="102"
                    src="https://hebergeurmarocain.com/wp-content/uploads/2022/12/ADK-MEDIA.png"
                    alt="ADK Media"
                    class="adk-hero-img"
                />
            </div>
        </div>
    </section>
    <AvisBestSeller />
</Layout>

<style>
    .adk-hero-section {
        position: relative;
        background-color: #0d1b39;
        overflow: hidden;
        transition:
            background 0.3s,
            border 0.3s,
            border-radius 0.3s,
            box-shadow 0.3s;
        margin-top: 0;
        margin-bottom: 0;
        padding: 100px 0;
        z-index: 1;
    }

    .adk-hero-bg-overlay {
        position: absolute;
        top: 0; 
        left: 0;
        width: 100%;
        height: 100%;
        background-image: url("https://hebergeurmarocain.com/wp-content/uploads/2022/03/hero-bg.jpg");
        background-position: center center;
        background-repeat: no-repeat;
        background-size: cover;
        opacity: 0.14;
        mix-blend-mode: multiply;
        transition:
            background 0.3s,
            border-radius 0.3s,
            opacity 0.3s;
        z-index: 0;
        pointer-events: none;
    }

    @media (min-width: 1025px) {
        .adk-hero-bg-overlay {
            background-attachment: fixed;
        }
    }

    .adk-hero-container {
        position: relative;
        z-index: 2;
        display: flex;
        align-items: center;
        max-width: 1140px;
        margin: 0 auto;
        padding: 0 20px;
    }

    .adk-hero-content {
        flex: 0 0 45%;
        max-width: 45%;
        padding-right: 60px;
    }

    .adk-hero-title-small {
        color: #ffffff;
        font-family: "Poppins", sans-serif;
        font-size: 18px;
        font-weight: 500;
        line-height: 28px;
        margin: 0 0 6px 0;
    }

    .adk-hero-title-main {
        color: #ffffff;
        font-family: "Poppins", sans-serif;
        font-size: 54px;
        font-weight: 700;
        line-height: 55px;
        margin: 0;
    }

    .adk-hero-image-col {
        flex: 0 0 55%;
        max-width: 55%;
        display: flex;
        justify-content: flex-end;
        align-items: center;
    }

    .adk-hero-img {
        width: 36%;
        height: auto;
        display: block;
    }

    /* Responsive overrides */
    @media (max-width: 1024px) {
        .adk-hero-section {
            padding: 150px 15px;
        }

        .adk-hero-content {
            flex: 0 0 50%;
            max-width: 50%;
            padding-right: 15px;
        }

        .adk-hero-image-col {
            flex: 0 0 50%;
            max-width: 50%;
            padding-left: 15px;
        }

        .adk-hero-title-small {
            font-size: 41px;
            line-height: 1.1em;
        }

        .adk-hero-title-main {
            font-size: 41px;
            line-height: 1.1em;
        }
    }

    @media (max-width: 767px) {
        .adk-hero-section {
            padding: 80px 25px;
        }

        .adk-hero-bg-overlay {
            background-position: bottom right;
        }

        .adk-hero-container {
            flex-direction: column;
            gap: 13px;
        }

        .adk-hero-content,
        .adk-hero-image-col {
            flex: 0 0 100%;
            max-width: 100%;
            padding: 0;
            text-align: center;
        }

        .adk-hero-title-small {
            font-size: 17px;
            line-height: 1.1em;
            margin: 0;
        }

        .adk-hero-title-main {
            font-size: 54px;
            line-height: 1.1em;
            margin: 0;
        }

        .adk-hero-image-col {
            justify-content: center;
            margin-top: 30px;
        }
        
        .adk-hero-img {
            width: 36%;
        }
    }
</style>