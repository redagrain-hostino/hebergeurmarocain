---
import AvisReviewClouder from "../../components/AvisReviewClouder.astro";
import Layout from "../../layouts/Layout.astro";
import AvisBestSeller from "../../components/AvisBestSeller.astro";
---

<Layout title="Avis Clouder - Hébergeur Marocain">
    <section class="clouder-hero-section">
        <div class="clouder-hero-bg-overlay" aria-hidden="true"></div>

        <div class="clouder-hero-container">
            <!-- Left Column: Text Content -->
            <div class="clouder-hero-content">
                <h1 class="clouder-hero-title-small">
                    Test Clouder.ma
                </h1>
                <h2 class="clouder-hero-title-main">Avis Clouder® 2025</h2>
            </div>

            <!-- Right Column: Logo/Image -->
            <div class="clouder-hero-image-col">
                <img
                    fetchpriority="high"
                    decoding="async"
                    width="800"
                    height="173"
                    src="/images/clouderma.png"
                    alt="Clouder"
                    srcset="/images/clouderma.png 800w, /images/clouderma-300x65.png 300w, /images/clouderma-768x166.png 768w"
                    sizes="(max-width: 800px) 100vw, 800px"
                    class="clouder-hero-img"
                />
            </div>
        </div>
    </section>
    
    <AvisBestSeller />
    <AvisReviewClouder />
</Layout>

<style>
    .clouder-hero-section {
        position: relative;
        background-color: #0d1b39;
        overflow: hidden;
        transition:
            background 0.3s,
            border 0.3s,
            border-radius 0.3s,
            box-shadow 0.3s;
        margin-top: 0;
        margin-bottom: 0;
        padding: 100px 0;
        z-index: 1;
    }

    .clouder-hero-bg-overlay {
        position: absolute;
        top: 0; 
        left: 0;
        width: 100%;
        height: 100%;
        background-image: url("/images/hero-bg.jpg");
        background-position: center center;
        background-repeat: no-repeat;
        background-size: cover;
        opacity: 0.14;
        mix-blend-mode: multiply;
        transition:
            background 0.3s,
            border-radius 0.3s,
            opacity 0.3s;
        z-index: 0;
        pointer-events: none;
    }

    @media (min-width: 1025px) {
        .clouder-hero-bg-overlay {
            background-attachment: fixed;
        }
    }

    .clouder-hero-container {
        position: relative;
        z-index: 2;
        display: flex;
        align-items: center;
        max-width: 1140px;
        margin: 0 auto;
        padding: 0 20px;
    }

    .clouder-hero-content {
        flex: 0 0 45%;
        max-width: 45%;
        padding-right: 60px;
    }

    .clouder-hero-title-small {
        color: #ffffff;
        font-family: "Poppins", sans-serif;
        font-size: 18px;
        font-weight: 500;
        line-height: 28px;
        margin: 0 0 6px 0;
    }

    .clouder-hero-title-main {
        color: #ffffff;
        font-family: "Montserrat", sans-serif;
        font-size: 54px;
        font-weight: 800;
        line-height: 1.1;
        margin: 0;
    }

    .clouder-hero-image-col {
        flex: 0 0 55%;
        max-width: 55%;
        display: flex;
        justify-content: flex-end;
        text-align: right;
    }

    .clouder-hero-img {
        max-width: 100%;
        height: auto;
        display: block;
        margin-left: auto;
        width: 47%;
        filter: brightness(200%) contrast(200%) saturate(100%) blur(0px) hue-rotate(0deg);
     }

    @media (max-width: 1024px) {
        .clouder-hero-container {
            flex-direction: column;
            text-align: center;
        }

        .clouder-hero-content {
            flex: 0 0 100%;
            max-width: 100%;
            padding-right: 0;
            margin-bottom: 40px;
        }

        .clouder-hero-image-col {
            flex: 0 0 100%;
            max-width: 100%;
        }

        .clouder-hero-title-main {
            font-size: 40px;
        }
    }

    @media (max-width: 767px) {
        .clouder-hero-title-main {
            font-size: 32px;
        }
    }
</style>