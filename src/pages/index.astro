---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Hébergeur Marocain - Meilleur hébergement web au Maroc">
	<main>
		<section class="hero-section">
			<div class="hero-bg-overlay" aria-hidden="true"></div>

			<div class="hero-shape-bottom" aria-hidden="true">
				<svg
					xmlns="http://www.w3.org/2000/svg"
					viewBox="0 0 1000 100"
					preserveAspectRatio="none"
				>
					<path class="hero-shape-fill" d="M0,100 L1000,0 L1000,100 Z"
					></path>
				</svg>
			</div>

			<div class="hero-container">
				<div class="hero-content">
					<h1 class="hero-title">Meilleur hébergeur web au Maroc</h1>

					<h2 class="hero-subtitle">
						Les 5 meilleurs hébergeurs web pour le Maroc (2025)
					</h2>

					<div class="hero-author">
						<img
							src="/images/reda-nabaoui.png"
							alt="Reda Nabaoui"
							width="60"
							height="60"
							class="hero-author-img"
							decoding="async"
						/>
						<div class="hero-author-meta">
							<h3 class="hero-author-name">Reda Nabaoui</h3>
							<p class="hero-author-date">
								Dernière mise à jour : 03 janvier 2024
							</p>
						</div>
					</div>

					<p class="hero-paragraph">
						Bonjour, Je m'appelle Reda! Je suis consultant expert en
						transformation digitale au Maroc depuis plus de 20 ans
						et j'ai construit de nombreux sites internet pour des
						entreprises de taille variée au Maroc.
					</p>
					<p class="hero-paragraph">
						Après des analyses approfondies et la récolte de données
						pendant 2 ans, j'ai listé les plus meilleurs hébergeurs
						web au Maroc pour l'année 2025.
					</p>
				</div>

				<div class="hero-image-col">
					<img
						src="/images/meilleur-hebergement-web-maroc.png"
						alt="Meilleur Hébergement web au Maroc"
						width="1200"
						height="1330"
						class="hero-img"
						fetchpriority="high"
						decoding="async"
					/>
				</div>
			</div>
		</section>
	</main>

