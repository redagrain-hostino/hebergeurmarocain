<style>
    /* Layout */
    .review-section {
        padding: 120px 0;
        background-color: #ffffff;
    }

    .review-container {
        max-width: 1140px;
        margin: 0 auto;
        padding: 0 15px;
        display: flex;
        flex-wrap: wrap;
        gap: 30px;
    }

    .review-main {
        flex: 0 0 66%;
        max-width: 66%;
        padding-right: 50px;
    }

    .review-sidebar {
        flex: 0 0 calc(34% - 30px);
        max-width: calc(34% - 30px);
    }

    /* Common typography */
    .emoji {
        width: 1em;
        height: 1em;
        vertical-align: -0.1em;
    }

    /* Left Column Typography */
    .review-title {
        color: #0a1a3b;
        font-family: "Montserrat", sans-serif;
        font-size: 54px;
        font-weight: 800;
        margin: 0 0 15px;
        line-height: 1.1;
    }

    .review-subtitle {
        color: #0a1a3b;
        font-family: "Montserrat", sans-serif;
        font-size: 32px;
        font-weight: 700;
        margin: 0 0 15px;
        line-height: 1.1;
    }

    .review-rating {
        color: #0a1a3b;
        font-family: "Montserrat", sans-serif;
        font-size: 36px;
        font-weight: 700;
        margin-bottom: 20px;
    }

    .review-content {
        color: #0a1a3b;
        font-family: "Montserrat", sans-serif;
        font-size: 17px;
        font-weight: 400;
        line-height: 1.6;
        margin-bottom: 26px;
    }

    .review-content p {
        margin-bottom: 15px;
    }

    .review-content ul {
        margin: 0 0 15px 20px;
        padding-left: 0;
    }

    .review-content li {
        margin-bottom: 5px;
    }

    .review-content a {
        color: #0a1a3b;
        text-decoration: underline;
    }

    /* Spacer */
    .review-spacer {
        height: 26px;
        width: 100%;
    }

    /* Buttons */
    .review-btn-wrap-left {
        margin-bottom: 30px;
    }

    .review-btn-visit {
        font-family: "Poppins", sans-serif;
        font-size: 17px;
        font-weight: 500;
        background-color: #51c726;
        color: #ffffff;
        padding: 10px 40px;
        display: inline-flex;
        flex-direction: row-reverse;
        align-items: center;
        gap: 13px;
        text-decoration: none;
        transition: background-color 0.3s;
    }

    .review-btn-visit-lg {
        font-family: "Poppins", sans-serif;
        font-size: 20px;
        font-weight: 500;
        background-color: #51c726;
        color: #ffffff;
        padding: 10px 50px;
        border-radius: 20px;
        display: inline-flex;
        flex-direction: row-reverse;
        align-items: center;
        gap: 13px;
        text-decoration: none;
        transition:
            background-color 0.3s,
            transform 0.3s;
    }

    .review-btn-visit-lg:hover {
        transform: scale(0.95);
    }

    /* Alert Box */
    .review-alert {
        background-color: #e5f0fa;
        border-left: 5px solid #2f5ab9;
        padding: 20px;
        position: relative;
        margin-bottom: 26px;
        font-family: "Montserrat", sans-serif;
    }

    .review-alert-title {
        font-weight: 700;
        color: #2f5ab9;
        margin-bottom: 10px;
        display: block;
    }

    .review-alert-desc {
        color: #0a1a3b;
        font-size: 15px;
        line-height: 1.6;
    }

    .review-alert-close {
        position: absolute;
        top: 10px;
        right: 15px;
        background: none;
        border: none;
        font-size: 20px;
        color: #2f5ab9;
        cursor: pointer;
    }

    /* Sidebar */
    .sidebar-card {
        border-radius: 10px;
        border: 1px solid rgba(0, 0, 0, 0.05); /* Assuming light border if boxed */
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.02);
        padding: 30px;
        margin-bottom: 30px;
        background: #fff;
    }

    .text-center {
        text-align: center;
    }

    .sidebar-rank-large {
        font-family: inherit;
        font-size: 36px;
        font-weight: 700;
        margin-bottom: 15px;
        color: #0a1a3b;
    }

    .sidebar-card-title {
        color: #0a1a3b;
        font-family: "Montserrat", sans-serif;
        font-size: 24px;
        font-weight: 700;
        margin-bottom: 15px;
    }

    .sidebar-card-title-sm {
        color: #0a1a3b;
        font-family: "Montserrat", sans-serif;
        font-size: 20px;
        font-weight: 700;
        margin-bottom: 15px;
    }

    .sidebar-stat {
        color: #0a1a3b;
        font-family: "Montserrat", sans-serif;
        font-size: 16px;
        margin-bottom: 10px;
        align-items: center;
    }

    .sidebar-score-large {
        color: #0a1a3b;
        font-family: "Montserrat", sans-serif;
        font-size: 40px;
        font-weight: 700;
        margin-bottom: 20px;
    }

    .sidebar-score-large .emoji {
        width: 50px;
        height: 50px;
    }

    /* Pro/Con elements */
    .pro-con-item {
        font-family: "Poppins", sans-serif;
        font-size: 14px;
        font-weight: 500;
        padding: 8px 15px;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 10px;
        border-radius: 4px;
    }

    .pro-con-item.pro {
        color: #198754;
        background-color: rgba(25, 135, 84, 0.1);
    }

    .pro-con-item.con {
        color: #dc3545;
        background-color: rgba(220, 53, 69, 0.1);
    }

    /* Responsive */
    @media (max-width: 1024px) {
        .review-main {
            flex: 0 0 100%;
            max-width: 100%;
            padding-right: 0;
            margin-bottom: 50px;
        }

        .review-sidebar {
            flex: 0 0 100%;
            max-width: 100%;
        }

        .review-title {
            font-size: 40px;
        }
    }

    @media (max-width: 767px) {
        .review-title {
            font-size: 32px;
        }

        .review-subtitle {
            font-size: 24px;
        }

        .review-btn-wrap-right,
        .review-btn-wrap-left {
            text-align: center;
        }
    }
</style>
