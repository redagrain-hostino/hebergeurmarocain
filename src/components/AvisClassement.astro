<style>
    .emoji {
        width: 1em;
        height: 1em;
        vertical-align: -0.1em;
    }

    .sidebar-card {
        border-radius: 10px;
        border: 1px solid rgba(0, 0, 0, 0.05);
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.02);
        padding: 30px;
        margin-bottom: 30px;
        background: #fff;
    }

    .sidebar-card-title-sm {
        color: #0a1a3b;
        font-family: "Montserrat", sans-serif;
        font-size: 20px;
        font-weight: 700;
        margin-bottom: 15px;
    }

    /* Ranking List inside Sidebar */
    .ranking-list {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .ranking-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px;
        border: 1px solid #eee;
        border-radius: 8px;
        text-decoration: none;
        color: inherit;
        transition: box-shadow 0.3s;
    }

    a.ranking-item:hover {
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
    }

    .ranking-num {
        font-weight: 700;
        font-size: 18px;
        color: #0a1a3b;
        width: 40px;
        display: flex;
        gap: 10px;
        align-items: center;
    }

    .ranking-logo-wrapper {
        flex: 1;
        text-align: center;
        padding: 0 10px;
    }

    .ranking-logo {
        max-width: 100px;
        max-height: 35px;
        height: auto;
        width: auto;
        object-fit: contain;
    }

    .ranking-score {
        font-weight: 700;
        color: #0a1a3b;
        font-size: 15px;
    }

    @media (max-width: 767px) {
        .ranking-logo {
            max-width: 80px;
        }
    }
</style>
