<style>
    /* ─────────────────────────────────────────────────────────────
    HOSTINO RANKING CARD SECTION
───────────────────────────────────────────────────────────── */
    .ranking-card-section {
        background-color: #ffffff;
        padding: 30px 0;
        background-color: #2f5ab9;
    }

    .ranking-card-container {
        margin: 0 auto;
        max-width: 1140px;
    }

    .ranking-card-body {
        padding: 20px 0;
        margin-top: 30px;
        display: flex;
        flex-wrap: wrap;
        padding-bottom: 70px;
    }

    .ranking-col-brand {
        flex: 0 0 100%;
        padding: 40px 0 0 50px;
    }
    @media (min-width: 768px) {
        .ranking-col-brand {
            flex: 0 0 39%;
            max-width: 39%;
        }
    }

    .ranking-brand-name {
        color: #ffffff;
        font-family: "Montserrat", sans-serif;
        font-size: 30px;
        font-weight: 700;
        margin: 0 0 15px;
    }

    .ranking-brand-img {
        max-width: 100%;
        height: auto;
        display: block;
        margin-bottom: 20px;
    }

    .ranking-brand-features {
        color: #ffffff;
        font-family: "Montserrat", sans-serif;
        font-size: 16px;
        font-weight: 400;
        line-height: 1.8;
        padding-left: 0;
        list-style: none;
        margin-top: 50px;
    }
    .ranking-brand-features li {
        padding: 0;
    }

    /* Middle column */
    .ranking-col-details {
        flex: 0 0 100%;
        padding: 50px 25px 0;
    }
    @media (min-width: 768px) {
        .ranking-col-details {
            flex: 0 0 42%;
            max-width: 42%;
        }
    }

    .ranking-details-logo {
        text-align: left;
        margin-bottom: 20px;
    }
    .ranking-details-logo-img {
        width: 160px;
        max-width: 100%;
        height: auto;
    }

    .ranking-section-title {
        color: #ffffff;
        font-family: "Montserrat", sans-serif;
        font-size: 25px;
        font-weight: 700;
        margin: 0 0 15px;
    }
    .ranking-section-title.mt-top {
        margin-top: 20px;
    }

    .ranking-stat {
        color: #ffffff;
        font-family: "Poppins", sans-serif;
        font-size: 16px;
        font-weight: 400;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 5px;
    }

    .ranking-stat-value {
        font-weight: 700;
    }

    .ranking-stat-stars img.emoji {
        width: 1em;
        height: 1em;
    }

    .ranking-summary {
        color: #ffffff;
        font-family: "Poppins", sans-serif;
        font-size: 16px;
        font-weight: 300;
        line-height: 1.6;
        margin-bottom: 20px;
    }

    .ranking-actions {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 20px;
        margin-bottom: 20px;
    }

    .ranking-btn-outline {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        color: #ffffff;
        font-family: "Poppins", sans-serif;
        font-size: 17px;
        font-weight: 300;
        text-shadow: 0px 0px 10px rgba(0, 0, 0, 0.3);
        background-color: transparent;
        border: 3px solid #ffffff;
        border-radius: 30px;
        padding: 11px 30px;
        text-decoration: none;
        transition: all 0.3s ease;
    }

    .ranking-btn-outline:hover {
        background-color: rgba(255, 255, 255, 0.1);
    }

    .ranking-score-number {
        color: #ffffff;
        font-family: "Montserrat", sans-serif;
        font-size: 44px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
    }
    .ranking-score-number img.emoji {
        width: 1em;
        height: 1em;
    }

    /* Right column */
    .ranking-col-badge {
        flex: 0 0 100%;
        padding: 25px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }
    @media (min-width: 768px) {
        .ranking-col-badge {
            flex: 0 0 18.333%;
            max-width: 18.333%;
        }
    }

    .ranking-badge-icon img.emoji,
    .ranking-badge-num {
        color: #ffffff;
        font-family: "Montserrat", sans-serif;
        font-size: 116px;
        font-weight: 700;
        line-height: 1;
        margin: 0;
    }
    .ranking-badge-icon img.emoji {
        width: 1em;
        height: 1em;
    }

    /* Footer CTA */
    .ranking-card-footer {
        background-color: #2f5ab9;
        padding: 0 0 50px;
        display: flex;
        justify-content: center;
    }

    .ranking-btn-primary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 13px;
        color: #ffffff;
        font-family: "Poppins", sans-serif;
        font-size: 21px;
        font-weight: 500;
        background-color: #51c726;
        border-radius: 30px;
        padding: 15px 60px;
        text-decoration: none;
        transition: background-color 0.3s ease;
        max-width: 100%;
    }
    .ranking-btn-primary i {
        font-weight: 900;
    }

    .ranking-btn-primary:hover {
        background-color: #45b31f; /* slightly darker on hover */
    }

    @media (min-width: 768px) {
        .ranking-btn-primary {
            padding: 15px 300px;
        }
    }

    @media (max-width: 1024px) {
        .ranking-col-brand,
        .ranking-col-details {
            padding: 40px 15px;
        }
    }

    @media (max-width: 767px) {
        .ranking-col-brand {
            padding: 19px;
        }
        .ranking-brand-name {
            font-size: 19px;
        }
        .ranking-section-title {
            font-size: 19px;
        }
        .ranking-col-badge {
            padding: 25px 0;
        }
        .ranking-badge-icon img.emoji,
        .ranking-badge-num {
            font-size: 67px;
        }
        .ranking-btn-outline {
            padding: 11px 20px;
        }
    }
</style>
